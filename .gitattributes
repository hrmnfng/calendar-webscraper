# Normalise line endings: LF in the repo, platform-native on checkout.
* text=auto eol=lf

*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env*  text eol=lf
.gitignore text eol=lf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
